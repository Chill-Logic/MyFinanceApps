# Este arquivo substitui o .gitignore na hora do EAS Build decidir o que empacotar e enviar
# pro servidor. Precisa existir porque env.ts (gitignored, gerado pelo CD antes do build) tem
# que ir junto no pacote - sem isso o Metro falha com "Unable to resolve module ../../../../env"
# dentro do build remoto, mesmo o arquivo existindo no disco do runner do CI.
#
# E uma copia do .gitignore, so que sem a linha "env.ts".

# OSX
#
.DS_Store

# Xcode
#
*.keystore
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
**/.xcode.env.local
.env*
!.env.example
# Android/IntelliJ
#
build/
release/
.idea
.gradle
local.properties
release.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore
.kotlin/

# node.js
#
node_modules/
npm-debug.log
yarn-error.log

# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
**/Pods/
/vendor/bundle/

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*

# testing
/coverage

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Expo
.expo/

# Continuous Native Generation - android/ e ios/ sao gerados via `npx expo prebuild`
# a partir do app.json, nao versionamos o resultado.
/android/
/ios/

# EAS Submit - chave da conta de servico do Google Cloud (Play Developer API)
# (nao precisa ir no pacote do build, so e lida localmente pelo eas-cli na hora do submit,
# mas mantemos fora por seguranca mesmo assim)
google-service-account.json
